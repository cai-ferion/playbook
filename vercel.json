{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/site",
      "destination": "/api/site/index.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/site/(.*\\.(?:js|css))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, immutable"
        }
      ]
    },
    {
      "source": "/api/site/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/roster-sync",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/attendance-sync",
      "schedule": "0 10 * * *"
    }
  ]
}
